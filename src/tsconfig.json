{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"esModuleInterop": true,
		"removeComments": false,
		"preserveConstEnums": true,
		"sourceMap": false,
		"allowJs": true,
		"resolveJsonModule": true,
		"isolatedModules": false,
		"outDir": "../out/vs",
		"types": [
			"@webgpu/types",
			"mocha",
			"semver",
			"sinon",
			"trusted-types",
			"winreg",
			"wicg-file-system-access"
		],
		"plugins": [
			{
				"name": "tsec",
				"exemptionConfig": "./tsec.exemptions.json"
			}
		]
	},
	"include": [
		"./*.ts",
		"./typings",
		"./vs/**/*.ts",
		"./vscode-dts/vscode.proposed.*.d.ts",
		"./vscode-dts/vscode.d.ts"
	],
	"exclude": [
		"vs/workbench/contrib/webview/browser/pre/service-worker.js",
		"./vs/platform/agentHost/**/*",
		"./vs/platform/mcp/**/*",
		"./vs/sessions/**/*",
		"./vs/workbench/contrib/chat/**/*",
		"./vs/workbench/contrib/inlineChat/**/*",
		"./vs/workbench/contrib/mcp/**/*",
		"./vs/workbench/contrib/imageCarousel/**/*",
		"./vs/workbench/contrib/terminalContrib/chat/**/*",
		"./vs/workbench/services/chat/**/*",
		"./vs/workbench/services/mcp/**/*",
		"./vs/**/test/**/*",
		"./vs/workbench/test/**/*",
		"./vs/sessions/test/**/*",
		"./vs/platform/agentHost/test/**/*",
		"./vs/platform/mcp/test/**/*",
		"./vs/platform/userDataSync/test/**/*",
		"./vs/workbench/services/accounts/browser/defaultAccount.ts",
		"./vs/workbench/services/aiEmbeddingVector/**/*",
		"./vs/workbench/services/aiRelatedInformation/**/*",
		"./vs/workbench/services/aiSettingsSearch/**/*",
		"./vs/workbench/api/**/*",
		"./vs/workbench/contrib/browserView/**/*",
		"./vs/workbench/contrib/notebook/**/*",
		"./vs/workbench/contrib/scm/**/*",
		"./vs/workbench/contrib/search/**/*",
		"./vs/workbench/contrib/terminal/**/*",
		"./vs/workbench/contrib/terminalContrib/**/*",
		"./vs/workbench/contrib/accessibility/**/*",
		"./vs/workbench/contrib/authentication/**/*",
		"./vs/workbench/contrib/codeEditor/**/*",
		"./vs/workbench/contrib/editTelemetry/**/*",
		"./vs/workbench/contrib/extensions/**/*",
		"./vs/workbench/contrib/inlineCompletions/**/*",
		"./vs/workbench/contrib/markers/**/*",
		"./vs/workbench/contrib/preferences/**/*",
		"./vs/workbench/contrib/quickaccess/**/*",
		"./vs/workbench/contrib/remoteCodingAgents/**/*",
		"./vs/workbench/contrib/tasks/**/*",
		"./vs/workbench/contrib/testing/**/*",
		"./vs/workbench/contrib/update/**/*",
		"./vs/workbench/contrib/welcomeAgentSessions/**/*",
		"./vs/workbench/contrib/welcomeGettingStarted/**/*",
		"./vs/workbench/services/agentHost/**/*",
		"./vs/workbench/services/assignment/**/*",
		"./vs/platform/agentPlugins/**/*",
		"./vs/server/node/serverAgentHostManager.ts",
		"./vs/workbench/contrib/debug/browser/debugChatIntegration.ts",
		"./vs/workbench/contrib/debug/browser/debugCommands.ts",
		"./vs/workbench/contrib/debug/browser/debugEditorActions.ts",
		"./server-cli.ts",
		"./server-main.ts",
		"./vs/server/node/**/*",
		"./vs/server/test/**/*"
	]
}
